{
  "name": "@funnycaptcha/embed",
  "version": "0.5.0",
  "description": "Script-tag embeddable FunnyChapter bundle",
  "type": "module",
  "main": "./dist/embed.js",
  "module": "./dist/embed.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/embed.js" },
    "./iife": "./dist/embed.global.js",
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": { "build": "tsup", "test": "vitest run", "typecheck": "tsc --noEmit" },
  "dependencies": {
    "@funnycaptcha/core": "workspace:*",
    "@funnycaptcha/math": "workspace:*",
    "@funnycaptcha/text-distort": "workspace:*",
    "@funnycaptcha/slider": "workspace:*",
    "@funnycaptcha/click-order": "workspace:*",
    "@funnycaptcha/rotate": "workspace:*",
    "@funnycaptcha/spot-diff": "workspace:*",
    "@funnycaptcha/emoji-match": "workspace:*",
    "@funnycaptcha/meme-quiz": "workspace:*",
    "@funnycaptcha/mini-game": "workspace:*",
    "@funnycaptcha/anti-bot": "workspace:*",
    "@funnycaptcha/click-text": "workspace:*",
    "@funnycaptcha/color-pick": "workspace:*",
    "@funnycaptcha/puzzle": "workspace:*"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
